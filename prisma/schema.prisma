// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // en | fr | pidgin; mirrored to PLAN2026_LOCALE when signed in
  preferredLocale  String?
  // light | dark | system; mirrored to PLAN2026_THEME when signed in
  preferredTheme   String?

  accounts            Account[]
  sessions            Session[]
  tasks               Task[]
  plans               Plan[]
  taskAttachments     TaskAttachment[]
  planAttachments     PlanAttachment[]
  plansSharedWithMe   PlanShare[]
  supplyItems         SupplyItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TaskStatus {
  active
  on_hold
  completed
}

enum TaskRecurrence {
  daily
  weekly
  monthly
}

model Task {
  id                    String     @id @default(cuid())
  userId                String
  title                 String
  content               String?    // optional rich text (sanitized HTML)
  dueAt                 DateTime?  // optional due date for Google Calendar
  /** When set, "Mark done" advances dueAt by one period and keeps the task active (single row). */
  recurrence            TaskRecurrence?
  urgency               Int        @default(4)
  googleCalendarEventId String?
  googleCalendarEventUrl String?
  status                TaskStatus @default(active)
  completedAt           DateTime?
  planId                String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
  attachments TaskAttachment[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, status, urgency(sort: Desc), createdAt(sort: Desc)])
  @@index([planId])
  @@index([planId, status, completedAt(sort: Desc), urgency(sort: Desc), createdAt(sort: Desc)])
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  url         String   // Vercel Blob or other blob storage URL
  filename    String
  size        Int      // bytes
  contentType String   @default("application/octet-stream")
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model Plan {
  id                 String    @id @default(cuid())
  userId             String
  name               String
  description        String?
  goal               String?
  startAt            DateTime
  endAt              DateTime
  actualStartAt      DateTime?
  actualEndAt        DateTime?
  status             String    @default("draft") // draft | started | on_hold | completed | abandoned
  priority           Int       @default(4) // 1-7 like task urgency
  percentCompleted   Int       @default(0)
  notes              String?
  color              String?
  imageUrl           String?
  /** When set, this uploaded file is shown as the plan thumbnail instead of imageUrl. */
  logoAttachmentId   String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks          Task[]
  shares         PlanShare[]
  shareLinks     PlanShareLink[]
  invites        PlanInvite[]
  supplyItems    SupplyItem[]
  attachments    PlanAttachment[]  @relation("PlanAttachments")
  logoAttachment PlanAttachment?   @relation("PlanLogo", fields: [logoAttachmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, priority])
  @@index([userId, status, priority(sort: Desc), createdAt(sort: Desc)])
}

model PlanAttachment {
  id          String   @id @default(cuid())
  planId      String
  userId      String
  url         String // Vercel Blob or other blob storage URL
  filename    String
  size        Int // bytes
  contentType String   @default("application/octet-stream")
  createdAt   DateTime @default(now())

  plan      Plan  @relation("PlanAttachments", fields: [planId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  logoForPlan Plan? @relation("PlanLogo")

  @@index([planId])
  @@index([userId])
}

model SupplyItem {
  id             String   @id @default(cuid())
  planId         String
  userId         String
  label          String
  price          Decimal? @db.Decimal(10, 2)
  description    String?
  link           String?
  quantity       Int      @default(1)
  acquiredStatus String   @default("needed") // needed | ordered | pending | purchased
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([planId, order, createdAt])
  @@index([userId])
}

model PlanShare {
  id               String   @id @default(cuid())
  planId           String
  sharedWithUserId String
  createdAt        DateTime @default(now())

  plan        Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  sharedWith  User @relation(fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([planId, sharedWithUserId])
  @@index([planId])
  @@index([sharedWithUserId])
  @@index([sharedWithUserId, planId])
}

model PlanShareLink {
  id                String    @id @default(cuid())
  planId            String
  token             String    @unique
  expiresAt         DateTime?
  allowStatusUpdate Boolean   @default(true)
  createdAt         DateTime  @default(now())

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([token])
}

model PlanInvite {
  id        String   @id @default(cuid())
  planId    String
  email     String?  // optional for link-based invite
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([token])
}
