{
  "name": "plan2026",
  "version": "0.24.4",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm exec next dev --webpack",
    "dev:kill": "pnpm exec kill-port 3000",
    "build": "node scripts/sync-about-changelog.mjs && prisma generate && next build",
    "build:next": "next build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:quick": "pnpm run typecheck && pnpm run lint",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepare": "husky",
    "prepush": "eslint && tsc --noEmit -p tsconfig.prepush.json",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --verbose",
    "sync:about": "node scripts/sync-about-changelog.mjs",
    "prisma:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:list-orphaned-completed-tasks": "tsx scripts/list-orphaned-completed-tasks.ts",
    "db:backfill-task-status": "tsx scripts/backfill-task-status.ts",
    "postinstall": "prisma generate && node scripts/sync-about-changelog.mjs",
    "pr": "gh pr create --fill --base main",
    "bulk:next": "node scripts/bulk-merge-and-next.mjs",
    "branch:report": "node scripts/branch-report.mjs",
    "squash": "node scripts/squash-soft.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "@tiptap/extension-placeholder": "3.20.4",
    "@tiptap/react": "3.20.4",
    "@tiptap/starter-kit": "3.20.4",
    "@vercel/blob": "2.3.1",
    "dotenv": "17.3.1",
    "googleapis": "171.4.0",
    "image-size": "^2.0.2",
    "lucide-react": "0.577.0",
    "next": "16.2.1",
    "next-auth": "4.24.13",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "2.17.2",
    "sonner": "2.0.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@next/bundle-analyzer": "16.2.1",
    "@prisma/config": "7.5.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitest/coverage-v8": "4.1.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "kill-port": "2.0.1",
    "prisma": "7.5.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "pnpm": {
    "overrides": {
      "@types/pg": "8.20.0"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
