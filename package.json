{
  "name": "plan2026",
  "version": "0.22.1",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:kill": "npx kill-port 3000",
    "build": "node scripts/sync-about-changelog.mjs && prisma generate && next build",
    "build:next": "next build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "prepush": "npm run lint && npm run typecheck",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --verbose",
    "sync:about": "node scripts/sync-about-changelog.mjs",
    "prisma:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate && node scripts/sync-about-changelog.mjs",
    "pr": "gh pr create --fill --base main",
    "bulk:next": "node scripts/bulk-merge-and-next.mjs",
    "branch:report": "node scripts/branch-report.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.2",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@vercel/blob": "^2.3.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sanitize-html": "^2.17.1",
    "sonner": "^1.7.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9",
    "jsdom": "^25.0.1",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
