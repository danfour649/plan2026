{
  "name": "plan2026",
  "version": "0.23.6",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:kill": "npx kill-port 3000",
    "build": "node scripts/sync-about-changelog.mjs && prisma generate && next build",
    "build:next": "next build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:quick": "npm run typecheck && npm run lint",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepare": "husky",
    "prepush": "npm run lint && npm run typecheck",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --verbose",
    "sync:about": "node scripts/sync-about-changelog.mjs",
    "prisma:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate && node scripts/sync-about-changelog.mjs",
    "pr": "gh pr create --fill --base main",
    "bulk:next": "node scripts/bulk-merge-and-next.mjs",
    "branch:report": "node scripts/branch-report.mjs",
    "git:squash": "node scripts/squash-soft.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.2",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@vercel/blob": "^2.3.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.2",
    "sonner": "^2.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
